# .gcloudignore - controls files uploaded by gcloud for Cloud Build / Cloud Run source deploys
# Based on .gitignore + docker-specific large/unneeded files.

node_modules/
dist/
coverage/
.env
.env.*
data/
playwright-report/
test-results/
*.log
*.tsbuildinfo
.DS_Store

# Docker / build artifacts not needed in source upload (Dockerfile rebuilds inside)
apps/server/dist/
apps/web/dist/
apps/web/dist-types/
packages/shared/dist/
packages/media/dist/

# Git and VCS
.git/
.gitignore
.gcloudignore

# OS / editor
.DS_Store
*.swp
*~

# Keep the Dockerfile, cloudbuild, yamls, scripts, source, package files, etc.
# Do NOT ignore the entire apps/ or packages/ source trees.

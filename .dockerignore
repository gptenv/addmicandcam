# Docker build context exclusions for smaller/faster builds on Cloud Build etc.
node_modules
.git
.gitignore
.gcloudignore
.env
.env.*
data/
dist/
apps/*/dist/
apps/*/dist-types/
apps/*/node_modules/
packages/*/dist/
playwright-report/
test-results/
*.log
*.tsbuildinfo
.DS_Store
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Keep source for build; the Dockerfile handles selective copy + build inside container

# Server
PORT=3000
HOST=0.0.0.0
APP_DATA_DIR=./data
NODE_ENV=development

# Security / rate limits (authentication has been removed; API is public)
MAX_SESSIONS=3
SESSION_TTL_MS=3600000
UPLOAD_MAX_BYTES=52428800

# URL controls
ALLOW_PRIVATE_NETWORKS=false
ALLOWED_URL_PATTERNS=
BLOCKED_URL_PATTERNS=

# Browser/media
HEADLESS=true
DEFAULT_VIEWPORT_WIDTH=1280
DEFAULT_VIEWPORT_HEIGHT=720
FAKE_VIDEO_DURATION_SECONDS=12
FAKE_VIDEO_FPS=30
DISCLOSURE_WATERMARK_ENABLED=true
DISCLOSURE_WATERMARK_LABEL=AI-assisted

# Optional tool overrides
FFMPEG_PATH=
ESPEAK_PATH=

# ------------------------------------------------------------------------------
# GCP Cloud Run / production deployment notes
# Copy relevant values into your Cloud Run service env vars or service.yaml.
# PUBLIC_BASE_URL should be set to the live https://*.run.app URL after deploy
#   so that API responses include correct absolute links for sessions.
# For ADMIN_TOKEN prefer Secret Manager (see scripts/deploy-gcp.sh and cloudbuild.yaml).
#
# Recommended Cloud Run settings (not .env, but service config):
#   memory: 2Gi, cpu: 2, concurrency: 1 (or low), max-instances: 5
#   --allow-unauthenticated (for easy testing) or use IAM + --no-allow-unauthenticated
#
# PORT and HOST are handled automatically in Cloud Run (set HOST=0.0.0.0).
# ------------------------------------------------------------------------------
# PUBLIC_BASE_URL=https://telepresence-lab-XXXXXX-uc.a.run.app
# ADMIN_TOKEN=your-strong-production-token-here
